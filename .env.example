# CurseForge API Key
# Required for downloading mods from CurseForge
# Get your key at: https://console.curseforge.com/
CURSEFORGE_API_KEY=your_curseforge_api_key_here

# GitHub Token (optional)
# Required for auto-updater with private repos
# Get your token at: https://github.com/settings/tokens
GH_TOKEN=your_github_token_here

# Apple Developer Credentials (optional, macOS only)
# Required for notarizing macOS builds
APPLE_ID=your@apple.id
APPLE_ID_PASSWORD=your_app_specific_password
APPLE_TEAM_ID=YOUR_TEAM_ID
